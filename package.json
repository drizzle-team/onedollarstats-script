{
  "name": "@unexpected/tracker",
  "scripts": {
    "bundle": "npx esbuild ./src/index.ts --bundle --minify --format=iife --outfile=./build/stonks.js",
    "bundle:test": "npx esbuild ./src/index.ts --bundle --format=cjs --outfile=./build/stonks.js",
    "test": "vitest run",
    "test:units": "vitest run --project 'Unit Tests'",
    "test:e2e": "vitest run --project 'Integration Tests'",
    "test:build&e2e": "pnpm bundle:test && FORCE_BUILD=1 COPY_TRACKER=1 vitest run --project 'Integration Tests'",
    "test:all": "pnpm bundle:test && FORCE_BUILD=1 COPY_TRACKER=1 vitest run",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@fingerprintjs/fingerprintjs": "^4.4.1",
    "jsdom": "^26.0.0",
    "node-fetch": "^2.7.0",
    "puppeteer": "^24.1.1",
    "puppeteer-core": "^24.1.1",
    "tsx": "^4.19.2",
    "vitest": "^3.0.5",
    "web-vitals": "^4.1.1"
  },
  "devDependencies": {
    "@types/jsdom": "^27.0.0",
    "esbuild": "^0.23.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.5.4"
  },
  "simple-git-hooks": {
    "pre-commit": "if [ \"$(git branch --show-current)\" = \"master\" ]; then pnpm bundle && pnpm test:all; fi"
  }
}

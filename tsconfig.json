{
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "dist",
    "outDir": "dist",
    "module": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "target": "ES2020",
    "strict": true,
    "moduleResolution": "bundler",
    "rootDir": "src",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "build", "**/*.test.ts"]
}
